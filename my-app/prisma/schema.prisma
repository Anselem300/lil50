generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  name      String?
  email     String   @unique
  password  String
  role      Role     @default(USER)
  createdAt DateTime @default(now())

  // Back-relations
  songs     Song[]
  videos    Video[]
}

model Song {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  fileUrl     String
  coverUrl    String?
  createdAt   DateTime @default(now())
  
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}

model Video {
  id          Int      @id @default(autoincrement())
  title       String
  description String?
  fileUrl     String
  thumbnail   String?
  createdAt   DateTime @default(now())

  userId      Int
  user        User     @relation(fields: [userId], references: [id])
}

enum Role {
  ADMIN
  USER
}